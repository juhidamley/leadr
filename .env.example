# Copy this file to .env and fill in real values. Never commit .env.
#
# Local dev (default): run `supabase start`, then use the ANON_KEY + API_URL
# it prints (also visible any time via `supabase status`). These are shared,
# publicly-known local dev defaults — safe to use as-is, not secrets.
#
# Hosted (Supabase dashboard → Project Settings → API): use the hosted
# project's URL + anon/publishable key when you need to point the app at
# the hosted backend instead of local.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Sign-In (Google Cloud Console → APIs & Services → Credentials).
# webClientId = the "Web application" OAuth client ID, used as the audience
# Supabase's Google provider verifies against (needed even though we never
# use it for a web flow). iosClientId = the "iOS" OAuth client ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Build-time only (baked into Info.plist by app.config.ts at prebuild), not
# shipped to the JS bundle — the reversed form of the iOS client ID:
# com.googleusercontent.apps.<the numeric part of EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID>
GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# Branch (branch.io dashboard → app settings) — invite deep links (Task 14).
# apiKey is baked into the native build by app.config.ts at prebuild; it's
# a client-embedded key (like a Stripe publishable key), not a server
# secret, but still isn't committed here. linkDomain is the app.link
# domain Branch provisions for this app — used for the iOS Universal
# Links / Android App Links config. See the Task 14 setup checklist.
EXPO_PUBLIC_BRANCH_KEY=key_live_your-branch-key
EXPO_PUBLIC_BRANCH_LINK_DOMAIN=leadr.app.link
