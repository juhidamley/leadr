# Copy this file to .env and fill in real values. Never commit .env.
#
# Local dev (default): run `supabase start`, then use the ANON_KEY + API_URL
# it prints (also visible any time via `supabase status`). These are shared,
# publicly-known local dev defaults — safe to use as-is, not secrets.
#
# Hosted (Supabase dashboard → Project Settings → API): use the hosted
# project's URL + anon/publishable key when you need to point the app at
# the hosted backend instead of local.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
